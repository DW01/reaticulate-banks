//! g="ProjectSAM/True Strike/Drums" n="Timpani"
//! m="Make sure SWITCHING is set to KEYSWITCH!"
//! id=b269c1de-1c57-4062-8a7a-bb9ae641a70a
Bank * * Timpani
//! c=long i=note-whole o=note:24/cc:64,0 c=#ff0000
1 open hit
//! c=long i=stopped o=note:24/cc:64,64 c=#ff8080
2 damped hit
//! spacer=1
//! c=fx i=tremolo o=note:25 c=#ff8000
3 tremolo
//! c=fx i=tremolo-measured-eighth o=note:26 c=#008000
4 rolls
//! c=fx i=fx o=note:27 c=#80ff00
5 fx

